{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Farmer",
  "version": "1.0.0",
  "identifier": "com.farmer.automation",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Farmer",
        "width": 1000,
        "height": 550,
        "minWidth": 800,
        "minHeight": 400,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwQTEyNjY3M0UyQjY5NDQKUldSRWFTcytaeWFoa0xEd0JpY3lkMkFMYXQ2U2F6RklVTjBhcnFUM0MxdlRjVWJhYVhkN0NmWTUK",
      "endpoints": [
        "https://github.com/oneone404/farmer/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../backend/assets/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  }
}